# This file outlines the backend environment variables required for running chaptered-api.

# Port that the Express server will listen on
PORT=3000

# Connection string for the MongoDB database
MONGODB_URI=mongodb://localhost:27017/chaptered

# JWT secret key for signing authentication tokens
JWT_SECRET=your_jwt_secret_here

# JWT token expiration time (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# URL of the React frontend application (used for CORS configuration)
CLIENT_URL=http://localhost:5173

# Google Books API key — get one at https://console.cloud.google.com/apis/credentials
# Without this, search will fall back to mock results only
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here
